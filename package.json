{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "lint": "eslint \"shell/**/*.{ts,tsx}\"",
    "lint:userland": "eslint \"userland/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:userland": "vitest run userland/src/__tests__/smoke.test.tsx",
    "typecheck": "tsc --noEmit",
    "typecheck:userland": "tsc --noEmit -p userland/tsconfig.json",
    "build:userland": "vite build --config userland/vite.config.ts",
    "build:shell": "vite build --config shell/vite.config.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "spike": "tsx scripts/spike.ts",
    "harden": "tsx scripts/harden.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.30.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.1.0",
    "vitest": "^3.2.4"
  }
}
